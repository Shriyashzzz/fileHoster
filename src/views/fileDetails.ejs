
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hwooster File</title>
    <link rel="stylesheet" href="/fileDetails.css">
    <link rel="icon" href="/icons/favicon.png" type="image/png">

</head>
<body>

    <% if (locals.fileLink) { %>
        <div class="shareLinkResult">
            <input type="text" id="shareLinkInput" value="<%= fileLink %>" readonly />
            <button type="button" id="copyLinkBtn">Copy</button>
        </div>
    <% } %> 

    <% if (locals.file) { %>   
    <div class="fileDetailsContainer">
        <h2><span class="fileNameText"><%= file.fileName %></span></h2>

        <div class="detailRow">
            <span class="detailLabel">Size</span>
            <span class="detailValue"><%= (file.size/1000).toFixed(0) %> kb</span>
        </div>
        <div class="detailRow">
            <span class="detailLabel">Uploaded</span>
            <span class="detailValue"><%= file.uploadTime %></span>
        </div>
        <button class = "shareFileBtn"
            type="button"
            command="show-modal"
            commandfor="shareFolderDialog">
            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M680-80q-50 0-85-35t-35-85q0-6 3-28L282-392q-16 15-37 23.5t-45 8.5q-50 0-85-35t-35-85q0-50 35-85t85-35q24 0 45 8.5t37 23.5l281-164q-2-7-2.5-13.5T560-760q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35q-24 0-45-8.5T598-672L317-508q2 7 2.5 13.5t.5 14.5q0 8-.5 14.5T317-452l281 164q16-15 37-23.5t45-8.5q50 0 85 35t35 85q0 50-35 85t-85 35Zm0-80q17 0 28.5-11.5T720-200q0-17-11.5-28.5T680-240q-17 0-28.5 11.5T640-200q0 17 11.5 28.5T680-160ZM200-440q17 0 28.5-11.5T240-480q0-17-11.5-28.5T200-520q-17 0-28.5 11.5T160-480q0 17 11.5 28.5T200-440Zm508.5-291.5Q720-743 720-760t-11.5-28.5Q697-800 680-800t-28.5 11.5Q640-777 640-760t11.5 28.5Q663-720 680-720t28.5-11.5ZM680-200ZM200-480Zm480-280Z"/></svg>
            Share
        </button>
        <a class="downloadFileBtn" href="/fileDownload/<%=file.id%>">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17V3"/><path d="m6 11 6 6 6-6"/><path d="M19 21H5"/></svg>
            Download
        </a>
    </div>
    <dialog id="shareFolderDialog">
        <button commandfor="shareFolderDialog" command="close" class="fileButton">
            X
        </button>

        <form id="shareFolderForm" action = "/shareLink/<%=file.id%>" method = "post">
            <legend>Share this File</legend>
            <label for="totSelect">Time To Expire: </label>
            <select name="totSelect" id="totSelect">
                <option value="1hr" selected>1 Hour</option>
                <option value="12hr">12 Hour</option>
                <option value="24hr">1 Day</option>
            </select>
            <button class="newFolderFileBtn" type="submit">Get Signed Link</button>
        </form>
    </dialog>

<% } %>
</body>
</html>


<script>
    document.getElementById("copyLinkBtn")?.addEventListener("click", () => {
        const input = document.getElementById("shareLinkInput");
        input.select();
        navigator.clipboard.writeText(input.value);
    });
</script>