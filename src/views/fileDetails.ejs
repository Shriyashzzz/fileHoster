
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/fileDetails.css">
</head>
<body>
  
    <% if (locals.file) { %>
    <div class="fileDetailsContainer">
        <h2><span class="fileNameText"><%= file.fileName %></span></h2>

        <div class="detailRow">
            <span class="detailLabel">Size</span>
            <span class="detailValue"><%= (file.size/1000).toFixed(0) %> kb</span>
        </div>
        <div class="detailRow">
            <span class="detailLabel">Uploaded</span>
            <span class="detailValue"><%= file.uploadTime %></span>
        </div>

        <a class="downloadFileBtn" href="<%= file.downloadUrl %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17V3"/><path d="m6 11 6 6 6-6"/><path d="M19 21H5"/></svg>
            Download
        </a>
    </div>
  
<% } %>
</body>
</html>


