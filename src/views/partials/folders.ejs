


<div class = "foldersContainer">
    <% if (locals.folders) { %>
        <% folders.map((folder)=>{%>
            <div class ="folderBtnBox">
                <div class="folder" data-folderid=<%= folder.id %>>
                    <div class = "folderName" > 
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder-icon lucide-folder"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg> <h4><%= folder.fileName %></h4>
                    </div>
              
                </div>
                <button data-buttonfolderid =<%=folder.id%> class = "deleteFolderBtn"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shredder-icon lucide-shredder"><path d="M4 13V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.706.706l3.588 3.588A2.4 2.4 0 0 1 20 8v5"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 22v-5"/><path d="M14 19v-2"/><path d="M18 20v-3"/><path d="M2 13h20"/><path d="M6 20v-3"/></svg></button>
            </div>
        <%  }) %>
    
    <% } %>
</div>

<script>
    const folders = document.querySelectorAll(".folder")
    const deleteBtns = document.querySelectorAll(".deleteFolderBtn")

    folders.forEach((folder) =>{
        folder.addEventListener("click", (async()=>{

            currentFolderId = folder.dataset.folderid;
            const folderId = folder.dataset.folderid;
            const response = await fetch(`/getFiles/${folderId}`, {
                method: "GET",
                headers: { 'Content-Type': 'application/json' }
            })
            const data = await response.json()
            if(data.redirectUrl){
                window.location.href = data.redirectUrl
            }
            }))
    })


    deleteBtns.forEach((btn) =>{
        btn.addEventListener("click", async()=>{
            const btnFolderId = btn.dataset.buttonfolderid;
            console.log("button id ", btnFolderId)
            const response = await fetch(`/deleteFolder/${btnFolderId}`, {
                method: "DELETE"
            })
            const data = await response.json()
            console.log(data)
            if(data.status == 200 && data.redirectUrl){
                window.location.href = data.redirectUrl
            }
        })
    })
</script>