<div class = "newFolderContainer">
  <button
    type="button"
    command="show-modal"
    commandfor="newFolderDialog"
    class="fileButton"
  >
   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder-plus-icon lucide-folder-plus"><path d="M12 10v6"/><path d="M9 13h6"/><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg><p>New Folder...</p>
  </button>
</div>
<dialog id="newFolderDialog">
  <button commandfor="newFolderDialog" command="close" class="fileButton">
    X
  </button>

  <form id="newFolderForm">
    <legend>Add a new folder</legend>
    <label for="folderNameInput">Folder Name: </label>
    <input
      type="text"
      id="folderNameInput"
      name="folderName"
      required
      minlength="1"
    />
    <button class="newFolderFileBtn" type="submit">Make a new Folder</button>
  </form>
  <% if (locals.newFolderErrorMessage) { %>
        <%= newFolderErrorMessage %>
  <% } %>   
</dialog>

<script>
  const newFolderFileBtn = document.querySelector(".newFolderFileBtn");
  const newFolderForm = document.querySelector("#newFolderForm");
  newFolderFileBtn.addEventListener("click", async (e) => {
    e.preventDefault();
    const form = new FormData(newFolderForm);

    const response = await fetch("/newFolder", {
      method: "POST",
      body: form,
    });
    if (response.ok) {
      const data = await response.json();
      if (data.status == 200 && data.redirectUrl) {
        window.location.href = data.redirectUrl;
      }
    }
  });
</script>
