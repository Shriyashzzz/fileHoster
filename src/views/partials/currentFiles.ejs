
<% if (locals.files.length != 0) { %>
    <% files.map((file) => { %>
        <div class = "fileContainer"><div class = "fileLogo"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-icon lucide-file"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/></svg>
            <a href="<%=`/getDetails/${file.id}`%>" ><%= file.fileName%></a>
        </div><div class = "fileEditContainer">
            <button 
            type="button"
            command="show-modal"
            commandfor="renameDialog"
            class="fileButton"            
            data-fileId = <%= file.id %> class = "renameAnchor"href=""><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-pen-icon lucide-file-pen"><path d="M12.659 22H18a2 2 0 0 0 2-2V8a2.4 2.4 0 0 0-.706-1.706l-3.588-3.588A2.4 2.4 0 0 0 14 2H6a2 2 0 0 0-2 2v9.34"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10.378 12.622a1 1 0 0 1 3 3.003L8.36 20.637a2 2 0 0 1-.854.506l-2.867.837a.5.5 0 0 1-.62-.62l.836-2.869a2 2 0 0 1 .506-.853z"/></svg></button>
            <a href="/deleteFile/<%=file.id %>"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-delete-icon lucide-delete"><path d="M10 5a2 2 0 0 0-1.344.519l-6.328 5.74a1 1 0 0 0 0 1.481l6.328 5.741A2 2 0 0 0 10 19h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2z"/><path d="m12 9 6 6"/><path d="m18 9-6 6"/></svg></a>
        </div></div>
       <dialog id="renameDialog">
            <button commandfor="renameDialog" command="close" class="fileButton">
                X
            </button>

            <form id="renameDialog" action="/renameFile/<%=file.id%>" method="post"> 
                <legend>Rename Your file!</legend>
                <label for="fileNameInput">New Name: </label>
                <input
                type="text"
                id="fileNameInput"
                name="fileName"
                required
                minlength="1"
                />
                <button class="newFolderFileBtn" type="submit">Done</button>
            </form>
            <% if (locals.renameErrorMessage) { %>
                    <%= renameErrorMessage %>
            <% } %>   
        </dialog>


    <% }) %>
    
<% }else{ %>
    <div class = "emptyFileBox"><h3>Folder is empty</h3>
      <%- include('./uploadFiles.ejs') %>
    </div>
  
<% } %>
    

